<?xml version="1.0"?>
<extension key="au.com.agileware.membershipcustomfieldsreport" type="module">
  <file>membershipcustomfieldsreport</file>
  <name>Memberships with Contact Custom Fields Report</name>
  <description>Extended membership report with support of filtering/showing custom fields of Individual contact.</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Agileware</author>
    <email>support@agileware.com.au</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://agileware.com.au</url>
    <url desc="Documentation">https://agileware.com.au</url>
    <url desc="Support">https://support.agileware.com.au</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-07-14</releaseDate>
  <version>1.2.1</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>5.82</ver>
  </compatibility>
  <civix>
    <namespace>CRM/Membershipcustomfieldsreport</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>smarty-v2@1.0.3</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
</extension>
